{
  "name": "RidgeRead",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "test:terrain": "node --import dotenv/config --import tsx --test \"server/tests/**/*.test.ts\"",
    "migrate:trophytrack": "node scripts/migrate-trophytrack-firestore.mjs",
    "import:huntreminder": "node scripts/import-huntreminder.js",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@quasar/extras": "^1.18.0",
    "@turf/turf": "^7.3.5",
    "@types/pngjs": "^6.0.5",
    "@vercel/analytics": "^2.0.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "firebase": "^12.12.0",
    "firebase-admin": "^13.8.0",
    "geotiff": "^3.0.5",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "openai": "^6.34.0",
    "pinia": "^3.0.4",
    "pngjs": "^7.0.0",
    "quasar": "^2.19.3",
    "vue": "^3.5.32",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@quasar/vite-plugin": "^1.11.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.5.2",
    "@vercel/node": "^5.7.13",
    "@vitejs/plugin-vue": "^6.0.5",
    "concurrently": "^9.2.1",
    "sass-embedded": "^1.99.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.0",
    "vite": "^8.0.8",
    "vue-tsc": "^3.2.6"
  }
}
