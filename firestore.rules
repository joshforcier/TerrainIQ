rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /customers/{uid} {
      allow read: if isOwner(uid);
      allow write: if false;

      match /subscriptions/{subscriptionId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      match /checkout_sessions/{sessionId} {
        allow read, create: if isOwner(uid);
        allow update, delete: if false;
      }

      match /usage/{monthId} {
        allow read: if isOwner(uid);
        allow write: if false;

        match /openaiAnalyses/{analysisId} {
          allow read: if isOwner(uid);
          allow write: if false;
        }
      }

      match /scoutWaypoints/{waypointId} {
        allow read, create, update, delete: if isOwner(uid);
      }

      match /feedback/{feedbackId} {
        allow create: if isOwner(uid)
          && request.resource.data.keys().hasOnly([
            'kind',
            'title',
            'message',
            'route',
            'userAgent',
            'email',
            'displayName',
            'status',
            'createdAt'
          ])
          && request.resource.data.kind in ['idea', 'feedback', 'bug']
          && request.resource.data.title is string
          && request.resource.data.title.size() >= 3
          && request.resource.data.title.size() <= 120
          && request.resource.data.message is string
          && request.resource.data.message.size() >= 10
          && request.resource.data.message.size() <= 4000
          && request.resource.data.status == 'new';
        allow read, update, delete: if false;
      }
    }

    match /analyses/{analysisId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /applications/{applicationId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /huntUnits/{stateId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /drawOdds/{huntDocId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /analysisCache/{cacheId} {
      allow read, write: if false;
    }

    match /users/{uid}/pins/{pinId} {
      allow read, create, update, delete: if isOwner(uid);
    }

    match /users/{uid}/points/{stateId} {
      allow read, create, update, delete: if isOwner(uid);
    }

    match /users/{uid}/meta/{metaId} {
      allow read, create, update, delete: if isOwner(uid);

      match /{document=**} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
